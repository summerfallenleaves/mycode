{
  // ── LLM Provider 配置 ──
  // defaultProvider 指定当前使用的提供商。
  // 每个 provider 通过 format 字段声明 API 格式：
  //   "openai"    → 使用 @ai-sdk/openai，兼容 DeepSeek / OpenAI API
  //   "anthropic" → 使用 @ai-sdk/anthropic，兼容 DeepSeek Anthropic 格式端点
  // API Key 读取优先级：环境变量 MYCODE_API_KEY > 配置文件中对应字段
  "llm": {
    "defaultProvider": "deepseek-openai",
    "providers": {
      "deepseek-openai": {
        "format": "openai",
        "baseUrl": "https://api.deepseek.com",
        "apiKey": "sk-****",
        "model": "deepseek-v4-flash",
        "contextWindow": 1_000_000,
        "maxOutputTokens": 384_000
      },
      "deepseek-anthropic": {
        "format": "anthropic",
        "baseUrl": "https://api.deepseek.com/anthropic",
        "apiKey": "sk-****",
        "model": "deepseek-v4-pro",
        "contextWindow": 1_000_000,
        "maxOutputTokens": 384_000
      }
    }
  },

  // ── MCP 服务器配置 ──
  // type: "stdio" → 本地子进程启动，command + args + env
  // type: "http"  → 远程 HTTP/SSE 连接，url + headers
  "mcpServers": {
    "web-search-prime": {
      "type": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer ****"
      }
    },
    "zai-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@z_ai/mcp-server"],
      "env": {
        "Z_AI_API_KEY": "****"
      }
    },
    "web-reader": {
      "type": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer ****"
      }
    },
    "zread": {
      "type": "http",
      "url": "https://open.bigmodel.cn/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer ****"
      }
    }
  },

  // ── Agent 运行时配置 ──
  "agent": {
    "systemPrompt": "你是mycode，由summerfallenleaves开发的AI助手。",
    "maxSteps": 25,
    "sessionTimeoutMs": 300_000,
    // 上下文窗口限制（字节数），超限后自动压缩
    "maxContextTokens": 128_000
  },

  // ── 技能目录 ──
  // skills/ 目录下的技能会被自动发现和注册
  "skills": {
    "enabled": true,
    "paths": [".mycode/skills"]
  },

  // ── 安全策略 ──
  "safety": {
    "toolTimeoutMs": 60_000,
    "maxToolCallsPerMinute": 20,
    "allowedCommands": ["ls", "cat", "head", "tail", "find", "grep", "pwd", "echo", "which", "node", "git"]
  },

  // ── 日志 ──
  "logging": {
    "level": "info",
    "file": ".mycode/agent.log"
  }
}
